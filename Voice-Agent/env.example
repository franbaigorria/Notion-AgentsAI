OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=...
GEMINI_API_KEY=AIza...

# ---------------------------------------------------------------------------
# Database — PostgreSQL via SQLAlchemy 2.x async (asyncpg driver)
# Required in all non-test environments. Missing → RuntimeError at startup.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:55432/voiceagent

# ---------------------------------------------------------------------------
# Credential Vault — Fernet symmetric encryption master key
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Required when instantiating FernetPostgresVault in non-test environments.
# Never commit the real key. Rotate by re-encrypting all secrets (see docs/key-rotation.md).
# ---------------------------------------------------------------------------
VAULT_MASTER_KEY=your-fernet-key-here

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to "true" to use PostgresTenantRegistry + FernetPostgresVault at runtime.
# Default: false — falls back to YAML-based load_vertical() for existing behaviour.
USE_TENANT_REGISTRY=false

# ---------------------------------------------------------------------------
# Runtime environment guard (set to "test" in CI / pytest to bypass DB guards)
# ---------------------------------------------------------------------------
# ENV=test
